# ============================================================
# Mali Daftari — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# ============================================================

# ------------------------------------------------------------
# Backend — Anthropic AI
# ------------------------------------------------------------

# Your Anthropic API key (https://console.anthropic.com/)
ANTHROPIC_API_KEY=sk-ant-...

# Claude model to use for chat completions
ANTHROPIC_MODEL=claude-sonnet-4-6

# ------------------------------------------------------------
# Backend — Supabase Auth
# ------------------------------------------------------------

# JWT secret from Supabase dashboard:
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# ------------------------------------------------------------
# MCP Server — Database
# ------------------------------------------------------------

# Full PostgreSQL connection string from Supabase:
# Project Settings → Database → Connection string → Transaction pooler (port 6543)
# Format: postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
